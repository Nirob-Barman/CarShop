@model IEnumerable<CarShop.Web.ViewModels.Car.CarViewModel>
@{
    ViewData["Title"] = "Manage Cars";
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Cars</h2>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Add New Car</a>
</div>

@if (TempData["SuccessMessage"] != null) { <div class="alert alert-success">@TempData["SuccessMessage"]</div> }
@if (TempData["ErrorMessage"] != null)   { <div class="alert alert-danger">@TempData["ErrorMessage"]</div> }

@if (!Model.Any())
{
    <div class="alert alert-info text-center">No cars available.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Title</th>
                    <th>Brand</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var car in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(car.ImageUrl))
                            {
                                <img src="@car.ImageUrl" alt="@car.Title"
                                     style="width:60px;height:44px;object-fit:cover;border-radius:4px;" />
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="fw-semibold">@car.Title</td>
                        <td>@car.BrandName</td>
                        <td>$@car.Price.ToString("N0")</td>
                        <td>
                            @if (car.Quantity > 0)
                            {
                                <span class="badge bg-success">@car.Quantity</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Out of stock</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@car.Id" class="btn btn-sm btn-outline-info">View</a>
                                <a asp-action="Edit" asp-route-id="@car.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                <form method="post" asp-action="Delete" asp-route-id="@car.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            onclick="confirmDeleteCar(this, '@car.Title')">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script src="~/js/pages/car-index.js" asp-append-version="true"></script>
}
