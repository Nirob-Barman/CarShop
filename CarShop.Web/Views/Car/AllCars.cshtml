@model IEnumerable<CarShop.Web.ViewModels.Car.CarViewModel>

@{
    ViewData["Title"] = "All Cars";
    var brands        = ViewBag.Brands as IEnumerable<CarShop.Web.ViewModels.Brand.BrandViewModel>;
    string selBrand   = ViewBag.SelectedBrand as string ?? "";
    string keyword    = ViewBag.SearchKeyword  as string ?? "";
    decimal? minPrice = ViewBag.MinPrice  as decimal?;
    decimal? maxPrice = ViewBag.MaxPrice  as decimal?;
    string sortBy     = ViewBag.SortBy    as string ?? "newest";
    int totalPages    = (int)(ViewBag.TotalPages ?? 1);
    int currentPage   = (int)(ViewBag.CurrentPage ?? 1);

    bool hasFilters = !string.IsNullOrEmpty(selBrand) || !string.IsNullOrEmpty(keyword)
                      || minPrice.HasValue || maxPrice.HasValue;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/allcars.css" asp-append-version="true" />
}

<div class="container">
    <div class="ac-page">

        <!-- ══ SIDEBAR ══ -->
        <aside class="ac-sidebar">
            <form method="get" asp-controller="Car" asp-action="AllCars" id="filterForm">

                <div class="ac-filter-card">
                    <span class="ac-filter-label">Search</span>
                    <input type="text" name="keyword" value="@keyword"
                           class="ac-search-input" placeholder="Search cars..." />
                </div>

                <div class="ac-filter-card">
                    <span class="ac-filter-label">Brand</span>
                    <div class="ac-brand-list">
                        <label class="ac-radio">
                            <input type="radio" name="brandName" value=""
                                   @(string.IsNullOrEmpty(selBrand) ? "checked" : "")
                                   onchange="this.form.submit()" />
                            All Brands
                        </label>
                        @foreach (var brand in brands!)
                        {
                            <label class="ac-radio">
                                <input type="radio" name="brandName" value="@brand.Name"
                                       @(selBrand == brand.Name ? "checked" : "")
                                       onchange="this.form.submit()" />
                                @brand.Name
                            </label>
                        }
                    </div>
                </div>

                <div class="ac-filter-card">
                    <span class="ac-filter-label">Price Range</span>
                    <div class="ac-price-row">
                        <input type="number" name="minPrice" value="@minPrice" min="0"
                               class="ac-price-input" placeholder="Min" />
                        <span class="ac-price-sep">–</span>
                        <input type="number" name="maxPrice" value="@maxPrice" min="0"
                               class="ac-price-input" placeholder="Max" />
                    </div>
                </div>

                <div class="ac-filter-card">
                    <span class="ac-filter-label">Sort By</span>
                    <select name="sortBy" class="ac-sort-select" onchange="this.form.submit()">
                        <option value="newest"     selected="@(sortBy == "newest"     ? "selected" : null)">Newest First</option>
                        <option value="price_asc"  selected="@(sortBy == "price_asc"  ? "selected" : null)">Price: Low to High</option>
                        <option value="price_desc" selected="@(sortBy == "price_desc" ? "selected" : null)">Price: High to Low</option>
                    </select>
                </div>

                <button type="submit" class="ac-btn-apply">Apply Filters</button>
                @if (hasFilters)
                {
                    <a asp-action="AllCars" class="ac-btn-clear">Clear Filters</a>
                }

            </form>
        </aside>

        <!-- ══ MAIN CONTENT ══ -->
        <div>
            <div class="ac-results-bar">
                <div>
                    <span class="ac-results-title">
                        @(string.IsNullOrEmpty(selBrand) ? "All Cars" : selBrand)
                    </span>
                    <span class="ac-results-count">@Model.Count() results</span>
                </div>
            </div>

            @if (hasFilters)
            {
                <div class="ac-active-filters">
                    @if (!string.IsNullOrEmpty(selBrand))
                    {
                        <a href="@Url.Action("AllCars", new { keyword, minPrice, maxPrice, sortBy })" class="ac-filter-tag">
                            @selBrand ×
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(keyword))
                    {
                        <a href="@Url.Action("AllCars", new { brandName = selBrand, minPrice, maxPrice, sortBy })" class="ac-filter-tag">
                            "@keyword" ×
                        </a>
                    }
                    @if (minPrice.HasValue || maxPrice.HasValue)
                    {
                        <a href="@Url.Action("AllCars", new { brandName = selBrand, keyword, sortBy })" class="ac-filter-tag">
                            $@(minPrice?.ToString("N0") ?? "0") – $@(maxPrice?.ToString("N0") ?? "∞") ×
                        </a>
                    }
                </div>
            }

            @if (Model.Any())
            {
                <div class="cs-car-grid">
                    @foreach (var car in Model)
                    {
                        <div class="cs-card">
                            <div class="cs-card__img-wrap">
                                <img src="@(string.IsNullOrEmpty(car.ImageUrl) ? "/images/no-image.png" : car.ImageUrl)"
                                     class="cs-card__img" alt="@car.Title" />
                            </div>
                            <div class="cs-card__body">
                                <div class="cs-card__brand">@car.BrandName</div>
                                <div class="cs-card__title">@car.Title</div>
                                <div class="cs-card__footer">
                                    <span class="cs-card__price">$@car.Price.ToString("N0")</span>
                                    @if (car.Quantity > 0) { <span class="cs-badge-in">In Stock</span> }
                                    else { <span class="cs-badge-out">Sold Out</span> }
                                </div>
                            </div>
                            <a asp-controller="Car" asp-action="Details" asp-route-id="@car.Id"
                               class="stretched-link" aria-label="View @car.Title"></a>
                        </div>
                    }
                </div>

                @if (totalPages > 1)
                {
                    <div class="ac-pagination">
                        @if (currentPage > 1)
                        {
                            <a class="ac-page-btn"
                               href="@Url.Action("AllCars", new { page = currentPage - 1, brandName = selBrand, keyword, minPrice, maxPrice, sortBy })">
                                ←
                            </a>
                        }
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <a class="ac-page-btn @(currentPage == i ? "active" : "")"
                               href="@Url.Action("AllCars", new { page = i, brandName = selBrand, keyword, minPrice, maxPrice, sortBy })">
                                @i
                            </a>
                        }
                        @if (currentPage < totalPages)
                        {
                            <a class="ac-page-btn"
                               href="@Url.Action("AllCars", new { page = currentPage + 1, brandName = selBrand, keyword, minPrice, maxPrice, sortBy })">
                                →
                            </a>
                        }
                    </div>
                }
            }
            else
            {
                <div class="ac-empty">
                    <div class="ac-empty__icon">🚗</div>
                    <div class="ac-empty__title">No cars found</div>
                    <p class="ac-empty__sub">Try adjusting your filters.</p>
                    <a asp-action="AllCars" class="cs-section-link">Clear Filters</a>
                </div>
            }
        </div>

    </div>
</div>
