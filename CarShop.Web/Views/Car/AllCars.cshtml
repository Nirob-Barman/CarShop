@model IEnumerable<CarShop.Web.ViewModels.Car.CarViewModel>

@{
    ViewData["Title"] = "All Cars";
    var brands        = ViewBag.Brands as IEnumerable<CarShop.Web.ViewModels.Brand.BrandViewModel>;
    string selBrand   = ViewBag.SelectedBrand as string ?? "";
    string keyword    = ViewBag.SearchKeyword  as string ?? "";
    decimal? minPrice = ViewBag.MinPrice  as decimal?;
    decimal? maxPrice = ViewBag.MaxPrice  as decimal?;
    string sortBy     = ViewBag.SortBy    as string ?? "newest";
    int totalPages    = (int)(ViewBag.TotalPages ?? 1);
    int currentPage   = (int)(ViewBag.CurrentPage ?? 1);
}

<div class="container-fluid mt-4 mb-5">
    <div class="row g-4">

        <!-- ══ SIDEBAR FILTERS ══ -->
        <div class="col-lg-3 col-md-4">
            <form method="get" asp-controller="Car" asp-action="AllCars" id="filterForm">

                <!-- Search -->
                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">🔍 Search</h6>
                        <input type="text" name="keyword" value="@keyword"
                               class="form-control form-control-sm" placeholder="Search cars..." />
                    </div>
                </div>

                <!-- Brand -->
                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">🏷️ Brand</h6>
                        <div class="brand-list" style="max-height:260px; overflow-y:auto;">
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="radio" name="brandName"
                                       id="brand-all" value=""
                                       @(string.IsNullOrEmpty(selBrand) ? "checked" : "")
                                       onchange="this.form.submit()" />
                                <label class="form-check-label" for="brand-all">All Brands</label>
                            </div>
                            @foreach (var brand in brands!)
                            {
                                <div class="form-check mb-1">
                                    <input class="form-check-input" type="radio" name="brandName"
                                           id="brand-@brand.Id" value="@brand.Name"
                                           @(selBrand == brand.Name ? "checked" : "")
                                           onchange="this.form.submit()" />
                                    <label class="form-check-label" for="brand-@brand.Id">@brand.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Price Range -->
                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">💰 Price Range</h6>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="number" name="minPrice" value="@minPrice" min="0"
                                   class="form-control form-control-sm" placeholder="Min" />
                            <span class="text-muted">–</span>
                            <input type="number" name="maxPrice" value="@maxPrice" min="0"
                                   class="form-control form-control-sm" placeholder="Max" />
                        </div>
                    </div>
                </div>

                <!-- Sort -->
                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">↕️ Sort By</h6>
                        <select name="sortBy" class="form-select form-select-sm" onchange="this.form.submit()">
                            <option value="newest"     selected="@(sortBy == "newest"     ? "selected" : null)">Newest First</option>
                            <option value="price_asc"  selected="@(sortBy == "price_asc"  ? "selected" : null)">Price: Low to High</option>
                            <option value="price_desc" selected="@(sortBy == "price_desc" ? "selected" : null)">Price: High to Low</option>
                        </select>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-sm">Apply Filters</button>
                    @if (!string.IsNullOrEmpty(selBrand) || !string.IsNullOrEmpty(keyword) || minPrice.HasValue || maxPrice.HasValue)
                    {
                        <a asp-action="AllCars" class="btn btn-outline-secondary btn-sm">Clear Filters</a>
                    }
                </div>

            </form>
        </div>

        <!-- ══ CAR GRID ══ -->
        <div class="col-lg-9 col-md-8">

            <!-- Results bar -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">
                    @if (!string.IsNullOrEmpty(selBrand))
                    {
                        <span>@selBrand</span>
                    }
                    else
                    {
                        <span>All Cars</span>
                    }
                    <span class="text-muted fw-normal fs-6 ms-2">(@Model.Count() results)</span>
                </h5>
            </div>

            @if (Model.Any())
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 g-4">
                    @foreach (var car in Model)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden">
                                <img src="@car.ImageUrl" class="card-img-top"
                                     style="height:200px; object-fit:cover;" alt="@car.Title" />
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold mb-1">@car.Title</h6>
                                    <small class="text-muted mb-2">@car.BrandName</small>
                                    <p class="text-success fw-bold mb-0 mt-auto">$@car.Price.ToString("N0")</p>
                                </div>
                                <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
                                    <a href="/Car/Details/@car.Id" class="btn btn-primary btn-sm w-100">View Details</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (totalPages > 1)
                {
                    <nav class="mt-4 d-flex justify-content-center">
                        <ul class="pagination">
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(currentPage == i ? "active" : "")">
                                    <a class="page-link"
                                       href="@Url.Action("AllCars", new { page = i, brandName = selBrand, keyword, minPrice, maxPrice, sortBy })">
                                        @i
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <div style="font-size:3rem;">🚗</div>
                    <h5 class="mt-3">No cars found</h5>
                    <p class="small">Try adjusting your filters.</p>
                    <a asp-action="AllCars" class="btn btn-outline-primary btn-sm">Clear Filters</a>
                </div>
            }

        </div>
    </div>
</div>
