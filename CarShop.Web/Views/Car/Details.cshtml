@model CarShop.Web.ViewModels.Car.CarViewModel
@{
    ViewData["Title"] = Model.Title;
    Layout = User.IsInRole("Admin")
        ? "~/Views/Shared/Admin/_AdminLayout.cshtml"
        : "~/Views/Shared/Car/_CarLayout.cshtml";

    var description = $"{Model.Title} by {Model.BrandName} — ${Model.Price:N2}. {(Model.Quantity > 0 ? "In stock." : "Out of stock.")}";
    ViewData["MetaDescription"] = description;
    ViewData["OgTitle"]         = Model.Title + " - CarShop";
    ViewData["OgDescription"]   = description;
    ViewData["OgImage"]         = Model.ImageUrl;
    ViewData["OgUrl"]           = $"{Context.Request.Scheme}://{Context.Request.Host}/Car/Details/{Model.Id}";

    var comments     = ViewBag.Comments as IEnumerable<CarShop.Application.DTOs.Comment.CommentDto>;
    var avgRating    = ViewBag.AverageRating as double? ?? 0;
    var isInWishlist = ViewBag.IsInWishlist as bool? ?? false;
    var isAlerted    = ViewBag.IsStockAlerted as bool? ?? false;
    var hasReviewed  = ViewBag.HasReviewed as bool? ?? false;
}

<div class="container mt-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible">@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="row mb-5">
        <div class="col-md-6 text-center">
            <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded shadow" style="max-height:400px;object-fit:contain;" />
        </div>
        <div class="col-md-6">
            <h1 class="mb-2">@Model.Title</h1>

            <!-- Star Rating Display -->
            <div class="mb-2">
                @for (int i = 1; i <= 5; i++)
                {
                    <span style="color:@(i <= Math.Round(avgRating) ? "#ffc107" : "#ccc"); font-size:1.4rem;">★</span>
                }
                <small class="text-muted ms-1">@(avgRating > 0 ? avgRating.ToString("F1") + " / 5" : "No ratings yet")</small>
            </div>

            <p>@Model.Description</p>
            <p><strong>Brand:</strong> @Model.BrandName</p>
            <p><strong>Stock:</strong>
                @if (Model.Quantity > 0)
                {
                    <span class="badge bg-success">@Model.Quantity available</span>
                }
                else
                {
                    <span class="badge bg-danger">Out of Stock</span>
                }
            </p>
            <p><strong>Price:</strong> <span class="text-success fw-bold fs-5">$@Model.Price.ToString("N2")</span></p>

            <!-- Social Share -->
            <div class="mt-3 mb-1 d-flex align-items-center gap-2 flex-wrap">
                <small class="text-muted fw-semibold">Share:</small>
                <a id="shareWhatsApp" href="#" target="_blank" rel="noopener" class="btn btn-sm btn-success">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                        <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
                    </svg>WhatsApp
                </a>
                <a id="shareFacebook" href="#" target="_blank" rel="noopener" class="btn btn-sm btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                        <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"/>
                    </svg>Facebook
                </a>
                <button id="copyLink" class="btn btn-sm btn-outline-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                        <path d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1.002 1.002 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4.018 4.018 0 0 1-.128-1.287z"/>
                        <path d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243L6.586 4.672z"/>
                    </svg><span id="copyLinkText">Copy Link</span>
                </button>
            </div>

            <!-- Admin actions -->
            @if (User.IsInRole("Admin"))
            {
                <div class="mt-3 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">✏️ Edit</a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline" id="deleteCarForm">
                        @Html.AntiForgeryToken()
                        <button type="button" class="btn btn-danger btn-sm"
                                onclick="confirmDeleteCar('@Model.Title')">🗑️ Delete</button>
                    </form>
                </div>
            }

            <!-- User actions -->
            @if (!User.IsInRole("Admin"))
            {
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (Model.Quantity > 0)
                    {
                        <form method="get" asp-controller="Payment" asp-action="Checkout" class="mb-2 mt-3">
                            <input type="hidden" name="carId" value="@Model.Id" />
                            <div class="input-group mb-2" style="max-width:320px;">
                                <input type="text" name="promoCode" class="form-control" placeholder="Promo code (optional)" />
                                <button type="submit" class="btn btn-warning fw-bold">Buy Now</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <p class="text-danger fw-bold mt-3">Out of Stock</p>
                        @if (!isAlerted)
                        {
                            <form asp-controller="StockAlert" asp-action="Subscribe" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="carId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-warning btn-sm">🔔 Notify me when back in stock</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted small">🔔 You'll be notified when back in stock</span>
                        }
                    }

                    <div class="mt-2">
                        @if (!isInWishlist)
                        {
                            <form asp-controller="Wishlist" asp-action="Add" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="carId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">♡ Add to Wishlist</button>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="Wishlist" asp-action="Remove" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="carId" value="@Model.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">♥ Remove from Wishlist</button>
                            </form>
                        }
                        <a asp-controller="TestDrive" asp-action="Book" asp-route-carId="@Model.Id"
                           class="btn btn-outline-secondary btn-sm ms-2">🚗 Book Test Drive</a>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary mt-3">Login to Buy</a>
                }
            }
        </div>
    </div>

    <!-- ═══════════════ REVIEWS ═══════════════ -->
    @{
        var reviews     = comments!.Where(c => c.Rating.HasValue).OrderByDescending(c => c.CreatedAt).ToList();
        var reviewCount = reviews.Count;
        var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    }

    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0">Customer Reviews <span class="badge bg-secondary ms-1">@reviewCount</span></h4>
            @if (avgRating > 0)
            {
                <div class="d-flex align-items-center gap-2">
                    <span class="fs-4 fw-bold text-warning">@avgRating.ToString("F1")</span>
                    <div>
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span style="color:@(i <= Math.Round(avgRating) ? "#ffc107" : "#dee2e6"); font-size:1.1rem;">★</span>
                        }
                    </div>
                    <small class="text-muted">out of 5</small>
                </div>
            }
        </div>

        @if (!reviews.Any())
        {
            <div class="text-center py-5 text-muted border rounded-3 bg-light">
                <div style="font-size:2.5rem;">★</div>
                <p class="mb-1 fw-semibold">No reviews yet</p>
                <small>Be the first to share your experience!</small>
            </div>
        }
        else
        {
            foreach (var c in reviews)
            {
                var isOwner   = currentUserId != null && c.UserId == currentUserId;
                var canEdit   = isOwner;
                var canDelete = isOwner || User.IsInRole("Admin");

                <div class="card mb-3 shadow-sm border-0" id="review-@c.Id">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-warning text-dark d-flex align-items-center justify-content-center fw-bold"
                                     style="width:40px;height:40px;font-size:.9rem;">
                                    @(c.UserName?.Length > 0 ? c.UserName[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="fw-semibold">@c.UserName</div>
                                    <small class="text-muted">@c.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</small>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <div>
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span style="color:@(i <= c.Rating ? "#ffc107" : "#dee2e6");">★</span>
                                    }
                                </div>
                                @if (canEdit || canDelete)
                                {
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border" data-bs-toggle="dropdown">⋯</button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            @if (canEdit)
                                            {
                                                <li>
                                                    <button class="dropdown-item" onclick="openEditModal(@c.Id, @c.Rating, '@Html.Raw(c.Content?.Replace("'", "\\'"))')">
                                                        ✏️ Edit Review
                                                    </button>
                                                </li>
                                            }
                                            @if (canDelete)
                                            {
                                                <li>
                                                    <button class="dropdown-item text-danger" onclick="openDeleteModal(@c.Id, @Model.Id)">
                                                        🗑️ Delete Review
                                                    </button>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </div>
                        </div>
                        <p class="mb-0 text-dark">@c.Content</p>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Write a Review -->
    @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
    {
        <div class="card shadow-sm border-0 mb-5">
            <div class="card-body">
                @if (!hasReviewed)
                {
                    <h5 class="fw-bold mb-3">Write a Review</h5>
                    <form asp-controller="Review" asp-action="AddReview" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="carId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Your Rating</label>
                            <div id="starPicker" style="display:flex;gap:6px;font-size:2rem;cursor:pointer;user-select:none;">
                                @for (int i = 1; i <= 5; i++) { <span class="sp-star" data-val="@i" style="color:#dee2e6;">★</span> }
                            </div>
                            <input type="hidden" name="rating" id="ratingValue" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Your Review</label>
                            <textarea name="content" class="form-control" rows="4" placeholder="Share your experience with this car..." required></textarea>
                        </div>
                        <button class="btn btn-warning fw-semibold px-4">Submit Review</button>
                    </form>
                }
                else
                {
                    <div class="d-flex align-items-center gap-2 text-muted">
                        <span style="font-size:1.5rem;">✔️</span>
                        <div>
                            <div class="fw-semibold text-dark">You've already reviewed this car</div>
                            <small>You can edit your review using the ⋯ menu above.</small>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (User.Identity?.IsAuthenticated != true)
    {
        <div class="card mb-5 border-0 bg-light">
            <div class="card-body text-center py-4">
                <p class="text-muted mb-2">Have you driven this car? Share your experience!</p>
                <a asp-controller="Account" asp-action="Login" class="btn btn-warning fw-semibold">Login to Write a Review</a>
            </div>
        </div>
    }

    <!-- Edit Review Modal -->
    <div class="modal fade" id="editReviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">Edit Your Review</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-controller="Review" asp-action="EditReview" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="commentId" id="editCommentId" />
                    <input type="hidden" name="carId" value="@Model.Id" />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Rating</label>
                            <div id="editStarPicker" style="display:flex;gap:6px;font-size:2rem;cursor:pointer;user-select:none;">
                                @for (int i = 1; i <= 5; i++) { <span class="ep-star" data-val="@i" style="color:#dee2e6;">★</span> }
                            </div>
                            <input type="hidden" name="rating" id="editRatingValue" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Review</label>
                            <textarea name="content" id="editContent" class="form-control" rows="4" required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning fw-semibold">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Review Modal -->
    <div class="modal fade" id="deleteReviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">Delete Review</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted mb-0">Are you sure you want to delete this review?</p>
                </div>
                <div class="modal-footer border-0">
                    <form asp-controller="Review" asp-action="DeleteReview" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="commentId" id="deleteCommentId" />
                        <input type="hidden" name="carId" id="deleteCarId" />
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({ icon:'success', title:'Done!', text:'@TempData["SuccessMessage"]',
                position:'top-end', timer:4000, toast:true, timerProgressBar:true, showConfirmButton:false });
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({ icon:'error', title:'Oops', text:'@TempData["ErrorMessage"]',
                position:'top-end', timer:5000, toast:true, timerProgressBar:true, showConfirmButton:false });
        </script>
    }
    <script>
        (function () {
            var url   = encodeURIComponent(window.location.href);
            var title = encodeURIComponent('@Html.Raw(Model.Title?.Replace("'", "\\'"))');
            document.getElementById('shareWhatsApp').href =
                'https://wa.me/?text=' + title + '%20' + url;
            document.getElementById('shareFacebook').href =
                'https://www.facebook.com/sharer/sharer.php?u=' + url;
            document.getElementById('copyLink').addEventListener('click', function () {
                navigator.clipboard.writeText(window.location.href).then(function () {
                    document.getElementById('copyLinkText').textContent = 'Copied!';
                    setTimeout(function () { document.getElementById('copyLinkText').textContent = 'Copy Link'; }, 2000);
                });
            });
        })();

        function confirmDeleteCar(title) {
            Swal.fire({
                title: 'Delete car?',
                text: "Delete '" + title + "'? This cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete'
            }).then(function (result) {
                if (result.isConfirmed) document.getElementById('deleteCarForm').submit();
            });
        }

        function makeStarPicker(pickerId, hiddenInputId, starClass) {
            const picker = document.getElementById(pickerId);
            const hidden = document.getElementById(hiddenInputId);
            if (!picker || !hidden) return;
            const stars = Array.from(picker.querySelectorAll('.' + starClass));
            let selected = 0;
            function paint(upTo) { stars.forEach((s, i) => s.style.color = i < upTo ? '#ffc107' : '#dee2e6'); }
            stars.forEach((star, idx) => {
                star.addEventListener('mouseover', () => paint(idx + 1));
                star.addEventListener('click', () => { selected = idx + 1; hidden.value = selected; paint(selected); });
            });
            picker.addEventListener('mouseleave', () => paint(selected));
            picker._setVal = (val) => { selected = val; hidden.value = val; paint(val); };
        }

        makeStarPicker('starPicker',     'ratingValue',     'sp-star');
        makeStarPicker('editStarPicker', 'editRatingValue', 'ep-star');

        function openEditModal(commentId, rating, content) {
            document.getElementById('editCommentId').value = commentId;
            document.getElementById('editContent').value   = content;
            const picker = document.getElementById('editStarPicker');
            if (picker && picker._setVal) picker._setVal(rating);
            new bootstrap.Modal(document.getElementById('editReviewModal')).show();
        }

        function openDeleteModal(commentId, carId) {
            document.getElementById('deleteCommentId').value = commentId;
            document.getElementById('deleteCarId').value     = carId;
            new bootstrap.Modal(document.getElementById('deleteReviewModal')).show();
        }
    </script>
}
