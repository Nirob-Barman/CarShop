@model CarShop.Web.ViewModels.Order.OrderViewModel
@{
    ViewData["Title"] = $"Order #{Model.Id}";
    Layout = "~/Views/Shared/User/_UserLayout.cshtml";

    string badgeClass = Model.Status switch
    {
        "Paid" or "Confirmed" => "bg-success",
        "Cancelled"           => "bg-danger",
        "Pending"             => "bg-warning text-dark",
        _                     => "bg-secondary"
    };
    string badgeLabel = Model.Status switch
    {
        "Paid"      => "Paid",
        "Confirmed" => "Confirmed",
        "Cancelled" => "Cancelled",
        "Pending"   => "Pending Payment",
        _           => Model.Status
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/order-print.css" asp-append-version="true" />
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-start">
        <div>
            <h5 class="fw-bold mb-0">Order #@Model.Id</h5>
            <small class="text-muted">Placed on @Model.OrderedAt.ToLocalTime().ToString("MMMM dd, yyyy 'at' hh:mm tt")</small>
        </div>
        <div class="d-flex gap-2 no-print">
            <button onclick="window.print()" class="btn btn-outline-secondary btn-sm">🖨️ Print Receipt</button>
            <a asp-action="MyOrders" class="btn btn-outline-secondary btn-sm">← Back</a>
        </div>
    </div>
    <div class="card-body p-4">

        <!-- Status -->
        <div class="mb-4">
            <span class="badge @badgeClass fs-6 px-3 py-2">@badgeLabel</span>
        </div>

        <!-- Car summary -->
        <div class="card border-0 bg-light rounded-3 mb-4">
            <div class="card-body d-flex gap-3 align-items-center">
                @if (!string.IsNullOrEmpty(Model.CarImageUrl))
                {
                    <img src="@Model.CarImageUrl" alt="@Model.CarTitle"
                         class="rounded" style="width:120px;height:85px;object-fit:cover;flex-shrink:0;" />
                }
                <div>
                    <h5 class="fw-bold mb-1">@Model.CarTitle</h5>
                    <a asp-controller="Car" asp-action="Details" asp-route-id="@Model.CarId"
                       class="btn btn-sm btn-outline-primary no-print">View Car</a>
                </div>
            </div>
        </div>

        <!-- Price breakdown -->
        <div class="card border-0 rounded-3 mb-4" style="background:#f8f9fa;">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Price Breakdown</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Car Price</span>
                    <span>$@Model.CarPrice.ToString("N2")</span>
                </div>
                @if (Model.DiscountAmount > 0)
                {
                    <div class="d-flex justify-content-between mb-2 text-success">
                        <span>Promo Code (@Model.PromoCode)</span>
                        <span>-$@Model.DiscountAmount.ToString("N2")</span>
                    </div>
                }
                <hr class="my-2" />
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total Paid</span>
                    <span class="text-success">$@Model.FinalPrice.ToString("N2")</span>
                </div>
            </div>
        </div>

        <!-- Actions -->
        @if (Model.Status == "Pending")
        {
            <div class="alert alert-warning no-print">
                <strong>Payment not completed.</strong>
                <a asp-controller="Payment" asp-action="Checkout" asp-route-carId="@Model.CarId"
                   class="btn btn-warning btn-sm ms-2 fw-semibold">Complete Payment</a>
            </div>
        }

    </div>
</div>
