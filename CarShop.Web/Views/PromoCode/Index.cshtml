@using CarShop.Application.DTOs.PromoCode
@model IEnumerable<PromoCodeDto>
@{
    ViewData["Title"] = "Promo Codes";
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Promo Codes</h2>
        <a asp-action="Create" class="btn btn-success">+ New Promo Code</a>
    </div>

    @if (TempData["SuccessMessage"] != null) { <div class="alert alert-success alert-dismissible">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["ErrorMessage"] != null)   { <div class="alert alert-danger alert-dismissible">@TempData["ErrorMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Code</th>
                        <th>Discount</th>
                        <th>Max Discount</th>
                        <th>Usages</th>
                        <th>Expires</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No promo codes yet.</td></tr>
                    }
                    @foreach (var p in Model)
                    {
                        bool isExpired = p.ExpiresAt.HasValue && p.ExpiresAt.Value < DateTime.UtcNow;
                        bool isMaxed   = p.MaxUsages.HasValue && p.UsageCount >= p.MaxUsages.Value;

                        <tr>
                            <td><code class="fs-6 fw-bold">@p.Code</code></td>
                            <td>@p.DiscountPercent%</td>
                            <td>@(p.MaxDiscountAmount.HasValue ? "$" + p.MaxDiscountAmount.Value.ToString("N2") : "—")</td>
                            <td>
                                @p.UsageCount / @(p.MaxUsages?.ToString() ?? "∞")
                                @if (isMaxed) { <span class="badge bg-warning text-dark ms-1">Maxed</span> }
                            </td>
                            <td>
                                @if (p.ExpiresAt.HasValue)
                                {
                                    <span class="@(isExpired ? "text-danger" : "")">
                                        @p.ExpiresAt.Value.ToString("MMM dd, yyyy")
                                        @if (isExpired) { <small>(Expired)</small> }
                                    </span>
                                }
                                else { <span class="text-muted">Never</span> }
                            </td>
                            <td>
                                <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")">
                                    @(p.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Edit" asp-route-id="@p.Id"
                                       class="btn btn-sm btn-outline-primary">Edit</a>

                                    <form asp-action="Toggle" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <button type="button" class="btn btn-sm @(p.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                onclick="confirmToggle(this, '@p.Code', @p.IsActive.ToString().ToLower())">
                                            @(p.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>

                                    <form asp-action="Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                onclick="confirmDelete(this, '@p.Code')">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/promo-index.js" asp-append-version="true"></script>
}
