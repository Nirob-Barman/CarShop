@using CarShop.Application.DTOs.PromoCode
@model IEnumerable<PromoCodeDto>
@{ ViewData["Title"] = "Deals & Promo Codes"; }

<div class="container mt-5" style="max-width:860px;">
    <div class="text-center mb-5">
        <div class="display-5 mb-2">🏷️</div>
        <h1 class="fw-bold">Deals & Promo Codes</h1>
        <p class="text-muted">Use any of the codes below at checkout to save on your next car.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <div class="fs-1 mb-3">😔</div>
            <h5>No active deals right now.</h5>
            <p>Check back soon — new offers are added regularly.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark mt-2">Back to Home</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var p in Model)
            {
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100"
                         style="border-left:5px solid #ffc107 !important;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <span class="badge bg-warning text-dark fs-6 px-3 py-2 fw-bold"
                                          style="letter-spacing:2px;">@p.Code</span>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold fs-4 text-success">@p.DiscountPercent.ToString("0")% OFF</div>
                                    @if (p.MaxDiscountAmount.HasValue)
                                    {
                                        <div class="text-muted small">up to $@p.MaxDiscountAmount.Value.ToString("N0") off</div>
                                    }
                                </div>
                            </div>

                            <ul class="list-unstyled text-muted small mb-3">
                                @if (p.MaxUsages.HasValue)
                                {
                                    var remaining = p.MaxUsages.Value - p.UsageCount;
                                    <li>🎫 <strong>@remaining</strong> use@(remaining == 1 ? "" : "s") remaining</li>
                                }
                                else
                                {
                                    <li>🎫 Unlimited uses</li>
                                }
                                @if (p.ExpiresAt.HasValue)
                                {
                                    <li>⏳ Expires <strong>@p.ExpiresAt.Value.ToString("MMM dd, yyyy")</strong></li>
                                }
                                else
                                {
                                    <li>⏳ No expiry date</li>
                                }
                            </ul>

                            <button class="btn btn-outline-dark btn-sm w-100"
                                    data-code="@p.Code"
                                    onclick="copyDealCode(this)">
                                📋 Copy Code
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-5">
            <a asp-controller="Car" asp-action="AllCars" class="btn btn-warning fw-bold px-5">
                Browse Cars & Apply Code →
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/pages/promo-deals.js" asp-append-version="true"></script>
}
