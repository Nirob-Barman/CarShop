<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] — CarShop Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/pages/admin-layout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@{
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    bool IsActive(string c, string a = "") =>
        ctrl.Equals(c, StringComparison.OrdinalIgnoreCase) &&
        (string.IsNullOrEmpty(a) || action.Equals(a, StringComparison.OrdinalIgnoreCase));

    bool IsAnyActive(params (string c, string a)[] items) =>
        items.Any(x => IsActive(x.c, x.a));

    string Ac(string c, string a = "") => IsActive(c, a) ? "active" : "";
}

<!-- ══════════════════════════════════════════
     SIDEBAR
     Desktop → position:fixed (always visible)
     Mobile  → Bootstrap offcanvas drawer
══════════════════════════════════════════ -->
<nav class="offcanvas offcanvas-start" id="adminSidebar" tabindex="-1" aria-labelledby="sidebarBrandLabel">

    <!-- Brand row -->
    <div class="sidebar-brand d-flex align-items-center justify-content-between">
        <a asp-controller="Admin" asp-action="Dashboard" class="d-flex align-items-center gap-2 text-decoration-none">
            <span class="fs-5 fw-bold text-warning" id="sidebarBrandLabel">🚗 CarShop</span>
            <span class="badge bg-warning text-dark" style="font-size:.6rem;">Admin</span>
        </a>
        <!-- Close button — only rendered on mobile offcanvas -->
        <button type="button" class="btn-close btn-close-white d-lg-none ms-2"
                data-bs-dismiss="offcanvas" data-bs-target="#adminSidebar" aria-label="Close sidebar"></button>
    </div>

    <!-- Overview -->
    <div class="pt-1">
        <a asp-controller="Admin" asp-action="Dashboard" class="nav-link @Ac("Admin","Dashboard")">
            📊 Dashboard
        </a>
    </div>

    <!-- Catalogue -->
    <div class="sidebar-section mt-1">Catalogue</div>
    <a asp-controller="Car"        asp-action="Index"  class="nav-link @Ac("Car","Index")">🚗 Cars</a>
    <a asp-controller="Brand"      asp-action="Index"  class="nav-link @Ac("Brand")">🏷️ Brands</a>
    <a asp-controller="BulkImport" asp-action="Index"  class="nav-link @Ac("BulkImport")">📥 Bulk Import</a>
    <a asp-controller="Reviews"    asp-action="Index"  class="nav-link @Ac("Reviews")">⭐ Reviews</a>

    <!-- Commerce -->
    <div class="sidebar-section mt-1">Commerce</div>
    <a asp-controller="Orders" asp-action="Index"
       class="nav-link @(IsAnyActive(("Orders","Index"),("Orders","Details")) ? "active" : "")">📦 Orders</a>
    <a asp-controller="PromoCode" asp-action="Index"
       class="nav-link @(IsAnyActive(("PromoCode","Index"),("PromoCode","Create"),("PromoCode","Edit")) ? "active" : "")">🎟️ Promo Codes</a>
    <a asp-controller="PaymentGateways" asp-action="Index"
       class="nav-link @(IsAnyActive(("PaymentGateways","Index"),("PaymentGateways","Add"),("PaymentGateways","Edit")) ? "active" : "")">💳 Payment Gateways</a>
    <a asp-controller="TestDrives" asp-action="Index"
       class="nav-link @Ac("TestDrives")">🚦 Test Drives</a>

    <!-- System -->
    <div class="sidebar-section mt-1">System</div>
    <a asp-controller="Users"     asp-action="Index"  class="nav-link @Ac("Users")">👥 Users</a>
    <a asp-controller="Roles"     asp-action="Index"  class="nav-link @(IsAnyActive(("Roles","Index"),("Roles","Create"),("Roles","Edit")) ? "active" : "")">🔑 Roles</a>
    <a asp-controller="AuditLogs" asp-action="Index"  class="nav-link @Ac("AuditLogs")">📋 Audit Logs</a>

    <!-- Footer: logout -->
    <div class="sidebar-footer">
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="nav-link btn btn-link w-100 text-start ps-0">🚪 Logout</button>
        </form>
    </div>

</nav>

<!-- ══════════════════════════════════════════
     MAIN AREA
══════════════════════════════════════════ -->
<div id="adminMain">

    <!-- Topbar -->
    <div id="adminTopbar" class="d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <button id="sidebarToggle" onclick="toggleSidebar()" title="Toggle sidebar">&#9776;</button>
            <h6 class="mb-0 fw-semibold text-dark">@ViewData["Title"]</h6>
        </div>
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="Home" asp-action="Index" target="_blank"
               class="text-decoration-none text-muted small d-flex align-items-center gap-1">
                🌐 <span class="d-none d-md-inline">View Site</span>
            </a>
            <div class="vr" style="height:1.2rem;"></div>
            <a asp-controller="Account" asp-action="Profile" class="text-decoration-none text-muted small">
                👤 @User.Identity!.Name
            </a>
        </div>
    </div>

    <!-- Page content -->
    <div id="adminContent">
        @RenderBody()
    </div>

    <!-- Footer -->
    <div id="adminFooter" class="d-flex justify-content-between">
        <span>&copy; @DateTime.Now.Year CarShop Admin</span>
        <span>ASP.NET Core 8</span>
    </div>

</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js" integrity="sha384-j1CDi7MgGQ12Z7Qab0qlWQ/Qqz24Gc6BM0thvEMVjHnfYGF0rmFCozFSxQBxwHKO" crossorigin="anonymous"></script>
<script src="~/js/pages/admin-layout.js" asp-append-version="true"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
