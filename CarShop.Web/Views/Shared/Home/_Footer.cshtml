<footer class="cs-footer">
    <div class="container">
        <div class="cs-footer__grid">
            <div class="cs-footer__brand-col">
                <div class="cs-footer__brand">CarShop</div>
                <p class="cs-footer__tagline">
                    Your one-stop destination for premium cars. Browse, compare, book test drives, and buy with confidence.
                </p>
                <div class="cs-footer__socials">
                    <a href="#" class="cs-footer__social" aria-label="Facebook">f</a>
                    <a href="#" class="cs-footer__social" aria-label="Twitter">𝕏</a>
                    <a href="#" class="cs-footer__social" aria-label="Instagram">in</a>
                </div>
            </div>

            <div>
                <div class="cs-footer__heading">Explore</div>
                <ul class="cs-footer__links">
                    <li><a asp-controller="Home" asp-action="Index" class="cs-footer__link">Home</a></li>
                    <li><a asp-controller="Car" asp-action="AllCars" class="cs-footer__link">All Cars</a></li>
                    <li><a asp-controller="TestDrive" asp-action="Book" class="cs-footer__link">Book Test Drive</a></li>
                    <li><a asp-controller="PromoCode" asp-action="Deals" class="cs-footer__link">Deals</a></li>
                    <li><a asp-controller="About" asp-action="Index" class="cs-footer__link">About Us</a></li>
                </ul>
            </div>

            <div>
                <div class="cs-footer__heading">Account</div>
                <ul class="cs-footer__links">
                    <li><a asp-controller="Account" asp-action="Login" class="cs-footer__link">Sign In</a></li>
                    <li><a asp-controller="Account" asp-action="Register" class="cs-footer__link">Register</a></li>
                    <li><a asp-controller="Order" asp-action="MyOrders" class="cs-footer__link">My Orders</a></li>
                    <li><a asp-controller="Wishlist" asp-action="Index" class="cs-footer__link">Wishlist</a></li>
                    <li><a asp-controller="StockAlert" asp-action="MyAlerts" class="cs-footer__link">Stock Alerts</a></li>
                </ul>
            </div>

            <div>
                <div class="cs-footer__heading">Contact</div>
                <ul class="cs-footer__links">
                    <li class="cs-footer__contact-item">123 Auto Avenue, Car City</li>
                    <li class="cs-footer__contact-item">+1 (555) 000-1234</li>
                    <li class="cs-footer__contact-item">support&#64;carshop.com</li>
                    <li class="cs-footer__contact-item">Mon–Sat: 9am – 7pm</li>
                </ul>
            </div>
        </div>

        <div class="cs-footer__bottom">
            <span>&copy; @DateTime.Now.Year CarShop. All rights reserved.</span>
            <span>Built with care for car lovers.</span>
        </div>
    </div>
</footer>

