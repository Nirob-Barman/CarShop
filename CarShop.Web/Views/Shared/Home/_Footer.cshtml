<footer class="bg-dark text-white pt-5 pb-3 mt-5">
    <div class="container">
        <div class="row g-4 mb-4">

            <!-- Col 1: Brand -->
            <div class="col-12 col-md-4">
                <h5 class="fw-bold text-warning mb-3">🚗 CarShop</h5>
                <p class="text-white-50 small">
                    Your one-stop destination for premium cars. Browse, compare, book test drives, and buy with confidence — all in one place.
                </p>
                <div class="d-flex gap-3 mt-3">
                    <a href="#" class="text-white-50 text-decoration-none fs-5" title="Facebook">&#xfb;</a>
                    <a href="#" class="text-white-50 text-decoration-none fs-5" title="Twitter/X">𝕏</a>
                    <a href="#" class="text-white-50 text-decoration-none fs-5" title="Instagram">📷</a>
                </div>
            </div>

            <!-- Col 2: Quick Links -->
            <div class="col-6 col-md-2 offset-md-1">
                <h6 class="fw-semibold text-uppercase text-warning-emphasis mb-3 small tracking-wide">Quick Links</h6>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><a asp-controller="Home" asp-action="Index" class="text-white-50 text-decoration-none footer-link">Home</a></li>
                    <li class="mb-2"><a asp-controller="Car" asp-action="AllCars" class="text-white-50 text-decoration-none footer-link">All Cars</a></li>
                    <li class="mb-2"><a asp-controller="TestDrive" asp-action="Book" class="text-white-50 text-decoration-none footer-link">Book Test Drive</a></li>
                    <li class="mb-2"><a asp-controller="Wishlist" asp-action="Index" class="text-white-50 text-decoration-none footer-link">Wishlist</a></li>
                    <li class="mb-2"><a asp-controller="Notification" asp-action="Index" class="text-white-50 text-decoration-none footer-link">Notifications</a></li>
                </ul>
            </div>

            <!-- Col 3: Account -->
            <div class="col-6 col-md-2">
                <h6 class="fw-semibold text-uppercase text-warning-emphasis mb-3 small">Account</h6>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><a asp-controller="Account" asp-action="Login" class="text-white-50 text-decoration-none footer-link">Login</a></li>
                    <li class="mb-2"><a asp-controller="Account" asp-action="Register" class="text-white-50 text-decoration-none footer-link">Register</a></li>
                    <li class="mb-2"><a asp-controller="Order" asp-action="MyOrders" class="text-white-50 text-decoration-none footer-link">My Orders</a></li>
                    <li class="mb-2"><a asp-controller="StockAlert" asp-action="MyAlerts" class="text-white-50 text-decoration-none footer-link">Stock Alerts</a></li>
                </ul>
            </div>

            <!-- Col 4: Contact -->
            <div class="col-12 col-md-3">
                <h6 class="fw-semibold text-uppercase text-warning-emphasis mb-3 small">Contact</h6>
                <ul class="list-unstyled text-white-50 small mb-0">
                    <li class="mb-2">📍 123 Auto Avenue, Car City, CC 10001</li>
                    <li class="mb-2">📞 +1 (555) 000-1234</li>
                    <li class="mb-2">✉️ support&#64;carshop.com</li>
                    <li class="mb-2">🕐 Mon–Sat: 9am – 7pm</li>
                </ul>
            </div>
        </div>

        <hr class="border-secondary" />

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center text-white-50 small">
            <span>&copy; @DateTime.Now.Year CarShop. All Rights Reserved.</span>
            <span class="mt-2 mt-md-0">Built with ❤️</span>
        </div>
    </div>
</footer>

