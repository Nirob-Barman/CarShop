@model CarShop.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Something Went Wrong";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height:70vh;">
    <div class="text-center">
        <div style="font-size:6rem;line-height:1;">⚠️</div>
        <h1 class="display-1 fw-bold text-muted mt-2">500</h1>
        <h2 class="fw-semibold mb-3">Something Went Wrong</h2>
        <p class="text-muted mb-2">
            An unexpected error occurred. Please try again later.
        </p>
        @if (Model?.ShowRequestId == true)
        {
            <p class="text-muted small mb-4">
                Request ID: <code>@Model.RequestId</code>
            </p>
        }
        <div class="d-flex gap-3 justify-content-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">Go Home</a>
            <a onclick="history.back()" class="btn btn-outline-secondary px-4" style="cursor:pointer;">Go Back</a>
        </div>
    </div>
</div>
