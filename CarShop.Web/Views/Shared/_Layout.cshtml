<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CarShop</title>
    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
    }
    @if (ViewData["OgTitle"] != null)
    {
        <meta property="og:title"       content="@ViewData["OgTitle"]" />
        <meta property="og:description" content="@ViewData["OgDescription"]" />
        <meta property="og:image"       content="@ViewData["OgImage"]" />
        <meta property="og:url"         content="@ViewData["OgUrl"]" />
        <meta property="og:type"        content="product" />
        <meta name="twitter:card"       content="summary_large_image" />
        <meta name="twitter:title"      content="@ViewData["OgTitle"]" />
        <meta name="twitter:description" content="@ViewData["OgDescription"]" />
        <meta name="twitter:image"      content="@ViewData["OgImage"]" />
    }
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CarShop.Web.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <style>
        .car {
            background-color: #ffc107;
            color: #fff;
            padding: 60px 20px;
            text-align: center;
            border-bottom: 4px solid #ffca2c;
        }

        .car h1 {
            font-size: 2.5rem;
            font-weight: bold;
        }
    </style>

</head>
<body>
    <header>
        @await Html.PartialAsync("_NavBar")
    </header>
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    @await Html.PartialAsync("Home/_Footer")
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
