<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - CarShop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="auth-layout">

    <!-- Left dark panel -->
    <aside class="auth-panel">
        <a href="/" class="auth-panel__logo">🚗 CarShop</a>

        <span class="auth-panel__eyebrow">Premium Car Marketplace</span>
        <h2 class="auth-panel__headline">Your Journey<br>Starts Here</h2>
        <p class="auth-panel__sub">Join thousands of car enthusiasts who find their perfect vehicle — from browsing to secure checkout, all in one place.</p>

        <ul class="auth-panel__features">
            <li class="auth-panel__feature">
                <span class="auth-panel__feature-dot"></span>
                <span class="auth-panel__feature-text"><strong>Hundreds of premium cars</strong> — curated listings with full specs and verified pricing.</span>
            </li>
            <li class="auth-panel__feature">
                <span class="auth-panel__feature-dot"></span>
                <span class="auth-panel__feature-text"><strong>Book test drives</strong> — schedule directly from any car listing, no waiting.</span>
            </li>
            <li class="auth-panel__feature">
                <span class="auth-panel__feature-dot"></span>
                <span class="auth-panel__feature-text"><strong>Secure multi-gateway checkout</strong> — Stripe, BKash, SSLCommerz, and more.</span>
            </li>
            <li class="auth-panel__feature">
                <span class="auth-panel__feature-dot"></span>
                <span class="auth-panel__feature-text"><strong>Wishlist & stock alerts</strong> — save favourites and get notified when a car restocks.</span>
            </li>
        </ul>

        <p class="auth-panel__copy">&copy; @DateTime.Now.Year CarShop. All rights reserved.</p>
    </aside>

    <!-- Right form area -->
    <div class="auth-form-area">
        @RenderBody()
    </div>

</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js" integrity="sha384-j1CDi7MgGQ12Z7Qab0qlWQ/Qqz24Gc6BM0thvEMVjHnfYGF0rmFCozFSxQBxwHKO" crossorigin="anonymous"></script>
@RenderSection("Scripts", required: false)

</body>
</html>
