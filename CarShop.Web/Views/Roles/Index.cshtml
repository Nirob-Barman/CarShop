@model IEnumerable<string>
@{
    ViewData["Title"] = "Roles";
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Roles</h2>
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Create Role</a>
    </div>

    @if (TempData["SuccessMessage"] != null) { <div class="alert alert-success">@TempData["SuccessMessage"]</div> }
    @if (TempData["ErrorMessage"] != null)   { <div class="alert alert-danger">@TempData["ErrorMessage"]</div> }

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr><th>#</th><th>Role Name</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">No roles found.</td></tr>
                }
                @{ int i = 1; }
                @foreach (var role in Model)
                {
                    var isProtected = role == "Admin" || role == "User";
                    <tr>
                        <td class="text-muted">@(i++)</td>
                        <td><span class="badge bg-secondary fs-6 fw-normal">@role</span></td>
                        <td>
                            @if (!isProtected)
                            {
                                <a asp-action="Edit" asp-route-roleName="@role"
                                   class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                <form asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="roleName" value="@role" />
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            onclick="confirmDeleteRole(this, '@role')">Delete</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">Protected</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDeleteRole(btn, roleName) {
            Swal.fire({
                title: 'Delete role?', text: "Delete role '" + roleName + "'?", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#dc3545', cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete', cancelButtonText: 'Cancel'
            }).then(function (result) { if (result.isConfirmed) btn.closest('form').submit(); });
        }
    </script>
}
