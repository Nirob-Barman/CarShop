@model string
@{
    ViewData["Title"] = "Edit Role";
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
}

<div class="container-fluid py-4" style="max-width:480px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
        <h2 class="mb-0">Edit Role</h2>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="currentName" value="@Model" />
        <div class="mb-3">
            <label class="form-label">Current Name</label>
            <input type="text" class="form-control" value="@Model" disabled />
        </div>
        <div class="mb-3">
            <label class="form-label">New Name</label>
            <input type="text" name="newName" class="form-control" placeholder="Enter new role name" required />
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>
