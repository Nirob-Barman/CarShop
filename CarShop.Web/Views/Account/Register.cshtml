@model CarShop.Web.ViewModels.Account.RegisterViewModel

@{
    ViewData["Title"] = "Create Account";
    Layout = "~/Views/Shared/Account/_AuthLayout.cshtml";
}

<div class="auth-card auth-card--wide">

    <div class="auth-card__icon">🚗</div>
    <h1 class="auth-card__title">Create your account</h1>
    <p class="auth-card__sub">Join CarShop and find your perfect car today.</p>

    <form id="registerForm" asp-action="Register" method="post" novalidate>

        <div class="auth-field">
            <label asp-for="FullName" class="auth-label">Full Name</label>
            <div class="auth-input-wrap">
                <input asp-for="FullName" class="auth-input" placeholder="John Doe" autocomplete="name" />
            </div>
            <span asp-validation-for="FullName" class="auth-error-msg"></span>
        </div>

        <div class="auth-field">
            <label asp-for="Email" class="auth-label">Email Address</label>
            <div class="auth-input-wrap">
                <input asp-for="Email" class="auth-input" placeholder="you@example.com" id="emailInput"
                       autocomplete="email" data-check-url="@Url.Action("CheckEmailExists", "Account")" />
            </div>
            <span asp-validation-for="Email" class="auth-error-msg"></span>
            <span id="emailError" class="auth-error-msg" style="display:none;">This email is already registered.</span>
        </div>

        <div class="auth-field">
            <label asp-for="Password" class="auth-label">Password</label>
            <div class="auth-input-wrap">
                <input asp-for="Password" type="password" class="auth-input auth-input-with-eye"
                       placeholder="••••••••" id="regPassword" autocomplete="new-password" />
                <button type="button" class="auth-eye" onclick="togglePassword('regPassword', this)"
                        tabindex="-1" aria-label="Toggle password visibility">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                        <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                    </svg>
                </button>
            </div>
            <span asp-validation-for="Password" class="auth-error-msg"></span>
            <div class="auth-strength" id="passwordStrength" style="display:none;">
                <div class="auth-strength-bar">
                    <div class="auth-strength-fill" id="strengthBar"></div>
                </div>
                <span class="auth-strength-label" id="strengthLabel"></span>
            </div>
            <ul id="passwordRequirements" class="small mt-1 mb-0 ps-3" style="display:none;">
                <li id="reqLength" class="text-muted">At least 6 characters</li>
                <li id="reqDigit" class="text-muted">At least one digit</li>
                <li id="reqLower" class="text-muted">At least one lowercase letter</li>
                <li id="reqUpper" class="text-muted">At least one uppercase letter</li>
                <li id="reqSpecial" class="text-muted">At least one special character</li>
            </ul>
        </div>

        <div class="auth-field">
            <label class="auth-label">Confirm Password</label>
            <div class="auth-input-wrap">
                <input type="password" class="auth-input auth-input-with-eye"
                       placeholder="••••••••" id="confirmPassword" autocomplete="new-password" />
                <button type="button" class="auth-eye" onclick="togglePassword('confirmPassword', this)"
                        tabindex="-1" aria-label="Toggle password visibility">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                        <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                    </svg>
                </button>
            </div>
            <span id="confirmError" class="auth-error-msg" style="display:none;">Passwords do not match.</span>
        </div>

        <div class="auth-field">
            <label asp-for="Address" class="auth-label">Address</label>
            <div class="auth-input-wrap">
                <input asp-for="Address" class="auth-input" placeholder="1234 Main St" autocomplete="street-address" />
            </div>
            <span asp-validation-for="Address" class="auth-error-msg"></span>
        </div>

        <button type="submit" id="submitBtn" class="auth-submit">Create Account</button>
    </form>

    <div class="auth-sep"><span class="auth-sep__text">or sign up with</span></div>

    <form asp-action="ExternalLogin" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="provider" value="Google" />
        <button type="submit" class="auth-google">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.34-8.16 2.34-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            Sign up with Google
        </button>
    </form>

    <div class="auth-card-footer">
        Already have an account? <a asp-action="Login">Sign in</a>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/emailValidation.js"></script>
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({ icon: 'error', title: 'Registration Failed', text: '@TempData["ErrorMessage"]', position: 'top-end', timer: 5000, toast: true, timerProgressBar: true, showConfirmButton: false });
        </script>
    }
    <script src="~/js/pages/auth.js" asp-append-version="true"></script>
    <script src="~/js/pages/register.js" asp-append-version="true"></script>
}
