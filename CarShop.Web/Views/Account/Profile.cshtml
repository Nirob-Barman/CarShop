@model CarShop.Web.ViewModels.Account.ProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
    Layout = "~/Views/Shared/User/_UserLayout.cshtml";
    ViewBag.UserFullName = Model?.FullName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
}

<div class="auth-card" style="max-width:none;">
    <div class="auth-card__icon">👤</div>
    <h2 class="auth-card__title">Profile Information</h2>
    <p class="auth-card__sub">Update your display name and address.</p>

    <form asp-action="EditProfile" method="post" novalidate>

        <div class="auth-field">
            <label class="auth-label">Email Address</label>
            <div class="auth-input-wrap">
                <input type="text" class="auth-input" value="@Model?.Email" readonly />
            </div>
            <span class="auth-hint">Email cannot be changed here.</span>
        </div>

        <div class="auth-field">
            <label asp-for="FullName" class="auth-label">Full Name</label>
            <div class="auth-input-wrap">
                <input asp-for="FullName" class="auth-input" placeholder="John Doe" />
            </div>
            <span asp-validation-for="FullName" class="auth-error-msg"></span>
        </div>

        <div class="auth-field">
            <label asp-for="Address" class="auth-label">Address</label>
            <div class="auth-input-wrap">
                <input asp-for="Address" class="auth-input" placeholder="1234 Main St" />
            </div>
            <span asp-validation-for="Address" class="auth-error-msg"></span>
        </div>

        <button type="submit" class="auth-submit">Save Changes</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({ icon:'success', title:'Saved!', text:'@TempData["SuccessMessage"]', position:'top-end', timer:4000, toast:true, timerProgressBar:true, showConfirmButton:false });
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({ icon:'error', title:'Error', text:'@TempData["ErrorMessage"]', position:'top-end', timer:5000, toast:true, timerProgressBar:true, showConfirmButton:false });
        </script>
    }
}
