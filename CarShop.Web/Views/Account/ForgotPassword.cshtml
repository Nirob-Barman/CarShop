@model CarShop.Web.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/Account/_AuthLayout.cshtml";
    bool sent = ViewBag.EmailSent == true;
}

<div class="auth-card">

    @if (sent)
    {
        <div class="auth-success">
            <div class="auth-success__icon">📧</div>
            <h1 class="auth-success__title">Check your inbox</h1>
            <p class="auth-success__sub">
                A password reset link has been sent to <strong>@Model?.Email</strong>.
                Follow the instructions in the email to reset your password.
            </p>
            <p class="auth-success__sub" style="font-size:.8125rem;">Didn't receive it? Check your spam folder.</p>
            <div style="display:flex;gap:10px;justify-content:center;margin-top:24px;flex-wrap:wrap;">
                <a asp-action="ForgotPassword" class="auth-btn-ghost" style="width:auto;padding:10px 20px;">Try Again</a>
                <a asp-action="Login" class="auth-submit" style="width:auto;padding:10px 24px;">Back to Sign In</a>
            </div>
        </div>
    }
    else
    {
        <div class="auth-card__icon">🔒</div>
        <h1 class="auth-card__title">Forgot password?</h1>
        <p class="auth-card__sub">Enter the email address for your account and we'll send you a reset link.</p>

        <form id="forgotForm" asp-action="ForgotPassword" method="post" novalidate>

            <div class="auth-field">
                <label asp-for="Email" class="auth-label">Email Address</label>
                <div class="auth-input-wrap">
                    <input asp-for="Email" class="auth-input" placeholder="you@example.com" id="emailInput"
                           autocomplete="email" data-check-url="@Url.Action("CheckEmailExists", "Account")" />
                </div>
                <span asp-validation-for="Email" class="auth-error-msg"></span>
                <span id="emailError" class="auth-error-msg" style="display:none;">No account found with this email.</span>
            </div>

            <button type="submit" class="auth-submit">Send Reset Link</button>
        </form>

        <div class="auth-card-footer" style="border-top:none;padding-top:12px;">
            <a asp-action="Login" class="auth-label-link" style="font-size:.8125rem;">← Back to Sign In</a>
        </div>
    }

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/emailValidation.js"></script>
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({ icon: 'error', title: 'Error', text: '@TempData["ErrorMessage"]', position: 'top-end', timer: 5000, toast: true, timerProgressBar: true, showConfirmButton: false });
        </script>
    }
    <script src="~/js/pages/forgot-password.js" asp-append-version="true"></script>
}
