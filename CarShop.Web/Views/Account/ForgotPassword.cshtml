@model CarShop.Web.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/Account/_AuthLayout.cshtml";
    bool sent = ViewBag.EmailSent == true;
}

<div class="card shadow-lg border-0 rounded-4 overflow-hidden">
    <div class="bg-warning text-dark text-center py-4 px-4">
        <div class="mb-2" style="font-size:2.5rem;">🔒</div>
        <h4 class="mb-0 fw-bold">Forgot Password?</h4>
        <small class="opacity-75">We'll send a reset link to your inbox</small>
    </div>
    <div class="card-body p-4">

        @if (sent)
        {
            <div class="text-center py-3">
                <div style="font-size:3rem;">📧</div>
                <h5 class="fw-bold mt-3">Check your email</h5>
                <p class="text-muted">
                    A password reset link has been sent to <strong>@Model?.Email</strong>.
                    Check your inbox and follow the instructions.
                </p>
                <p class="text-muted small">Didn't receive it? Check your spam folder or try again.</p>
                <a asp-action="ForgotPassword" class="btn btn-outline-warning me-2">Try Again</a>
                <a asp-action="Login" class="btn btn-primary">Back to Login</a>
            </div>
        }
        else
        {
            <form id="forgotForm" asp-action="ForgotPassword" method="post" novalidate>
                <p class="text-muted small mb-3">Enter the email address associated with your account and we'll send you a reset link.</p>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                    <input asp-for="Email" class="form-control form-control-lg" placeholder="you@example.com" id="emailInput" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                    <div id="emailError" class="text-danger small mt-1" style="display:none;">This email is not registered.</div>
                </div>

                <button type="submit" class="btn btn-warning btn-lg w-100 fw-semibold text-dark">Send Reset Link</button>
            </form>

            <hr class="my-4">
            <div class="text-center">
                <a asp-action="Login" class="small text-decoration-none text-muted">← Back to Login</a>
            </div>
        }

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/emailValidation.js"></script>
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({ icon: 'error', title: 'Error', text: '@TempData["ErrorMessage"]', position: 'top-end', timer: 5000, toast: true, timerProgressBar: true, showConfirmButton: false });
        </script>
    }
    @if (!sent)
    {
        <script>
            document.getElementById('forgotForm').addEventListener('submit', function (e) {
                e.preventDefault();
                const email = document.getElementById('emailInput').value;
                if (!email || !validateEmailFormat(email)) return;
                $.ajax({
                    url: '@Url.Action("CheckEmailExists", "Account")',
                    type: 'POST',
                    data: { email },
                    success: function (exists) {
                        if (!exists) {
                            document.getElementById('emailError').style.display = 'block';
                        } else {
                            document.getElementById('emailError').style.display = 'none';
                            document.getElementById('forgotForm').submit();
                        }
                    },
                    error: function () {
                        Swal.fire({ icon: 'error', title: 'Oops...', text: 'Error checking email', toast: true, position: 'top-end', timer: 4000, showConfirmButton: false });
                    }
                });
            });
        </script>
    }
}
