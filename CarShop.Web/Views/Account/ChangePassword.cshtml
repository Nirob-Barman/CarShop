@model CarShop.Web.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/User/_UserLayout.cshtml";
    ViewBag.UserFullName = ViewBag.FullName as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
}

<div class="auth-card" style="max-width:none;">
    <div class="auth-card__icon">🔒</div>
    <h2 class="auth-card__title">Change Password</h2>
    <p class="auth-card__sub">Update your account password. You'll stay logged in after saving.</p>

    <form asp-action="ChangePassword" method="post" novalidate>

        <div class="auth-field">
            <label asp-for="CurrentPassword" class="auth-label">Current Password</label>
            <div class="auth-input-wrap">
                <input asp-for="CurrentPassword" type="password" class="auth-input auth-input-with-eye"
                       placeholder="Enter current password" id="currentPwd" autocomplete="current-password" />
                <button type="button" class="auth-eye" onclick="togglePwd('currentPwd', this)"
                        tabindex="-1" aria-label="Toggle password visibility">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                        <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                    </svg>
                </button>
            </div>
            <span asp-validation-for="CurrentPassword" class="auth-error-msg"></span>
        </div>

        <div class="auth-field">
            <label asp-for="NewPassword" class="auth-label">New Password</label>
            <div class="auth-input-wrap">
                <input asp-for="NewPassword" type="password" class="auth-input auth-input-with-eye"
                       placeholder="Enter new password" id="newPwd" autocomplete="new-password" />
                <button type="button" class="auth-eye" onclick="togglePwd('newPwd', this)"
                        tabindex="-1" aria-label="Toggle password visibility">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                        <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                    </svg>
                </button>
            </div>
            <span asp-validation-for="NewPassword" class="auth-error-msg"></span>
            <div class="auth-strength" id="strengthWrap" style="display:none;">
                <div class="auth-strength-bar">
                    <div class="auth-strength-fill" id="strengthBar"></div>
                </div>
                <span class="auth-strength-label" id="strengthLabel"></span>
            </div>
        </div>

        <div class="auth-field">
            <label asp-for="ConfirmPassword" class="auth-label">Confirm New Password</label>
            <div class="auth-input-wrap">
                <input asp-for="ConfirmPassword" type="password" class="auth-input auth-input-with-eye"
                       placeholder="Confirm new password" id="confirmPwd" autocomplete="new-password" />
                <button type="button" class="auth-eye" onclick="togglePwd('confirmPwd', this)"
                        tabindex="-1" aria-label="Toggle password visibility">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                        <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                    </svg>
                </button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="auth-error-msg"></span>
            <span id="matchError" class="auth-error-msg" style="display:none;">Passwords do not match.</span>
        </div>

        <div style="display:flex;gap:10px;">
            <button type="submit" class="auth-submit">Update Password</button>
            <a asp-action="Profile" class="auth-btn-ghost" style="width:auto;padding:12px 20px;">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({ icon:'error', title:'Error', text:'@TempData["ErrorMessage"]', position:'top-end', timer:5000, toast:true, timerProgressBar:true, showConfirmButton:false });
        </script>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({ icon:'success', title:'Password Updated', text:'@TempData["SuccessMessage"]', position:'top-end', timer:4000, toast:true, timerProgressBar:true, showConfirmButton:false });
        </script>
    }
    <script src="~/js/pages/auth.js" asp-append-version="true"></script>
    <script src="~/js/pages/change-password.js" asp-append-version="true"></script>
}
