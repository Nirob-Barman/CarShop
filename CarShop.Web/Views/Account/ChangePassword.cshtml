@model CarShop.Web.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/User/_UserLayout.cshtml";
    ViewBag.UserFullName = ViewBag.FullName as string;

    string eyeIcon = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" fill=\"currentColor\" viewBox=\"0 0 16 16\"><path d=\"M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z\"/><path d=\"M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z\"/></svg>";
}

<style>
    /* Hide Edge's native password reveal button to avoid double eye icons */
    input[type="password"]::-ms-reveal,
    input[type="password"]::-ms-clear { display: none; }
</style>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
        <h5 class="fw-bold mb-0">Change Password</h5>
        <small class="text-muted">Update your account password</small>
    </div>
    <div class="card-body p-4">
        <form asp-action="ChangePassword" method="post" novalidate>

            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label fw-semibold">Current Password</label>
                <div class="input-group">
                    <input asp-for="CurrentPassword" type="password" class="form-control form-control-lg"
                           placeholder="Enter current password" id="currentPwd" autocomplete="current-password" />
                    <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('currentPwd', this)" tabindex="-1">@Html.Raw(eyeIcon)</button>
                </div>
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
                <div class="input-group">
                    <input asp-for="NewPassword" type="password" class="form-control form-control-lg"
                           placeholder="Enter new password" id="newPwd" autocomplete="new-password" />
                    <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('newPwd', this)" tabindex="-1">@Html.Raw(eyeIcon)</button>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                <div id="strengthWrap" class="mt-2" style="display:none;">
                    <div class="progress" style="height:4px;">
                        <div id="strengthBar" class="progress-bar" role="progressbar" style="width:0%"></div>
                    </div>
                    <small id="strengthLabel" class="text-muted"></small>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm New Password</label>
                <div class="input-group">
                    <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg"
                           placeholder="Confirm new password" id="confirmPwd" autocomplete="new-password" />
                    <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('confirmPwd', this)" tabindex="-1">@Html.Raw(eyeIcon)</button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                <div id="matchError" class="text-danger small mt-1" style="display:none;">Passwords do not match.</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4 fw-semibold">Update Password</button>
                <a asp-action="Profile" class="btn btn-outline-secondary px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({ icon:'error', title:'Error', text:'@TempData["ErrorMessage"]', position:'top-end', timer:5000, toast:true, timerProgressBar:true, showConfirmButton:false });
        </script>
    }
    <script>
        const eyeOn  = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/></svg>';
        const eyeOff = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z"/><path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/><path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z"/></svg>';

        function togglePwd(id, btn) {
            const input = document.getElementById(id);
            const show  = input.type === 'password';
            input.type  = show ? 'text' : 'password';
            btn.innerHTML = show ? eyeOff : eyeOn;
        }

        document.getElementById('newPwd').addEventListener('input', function () {
            const p    = this.value;
            const wrap = document.getElementById('strengthWrap');
            if (!p) { wrap.style.display = 'none'; return; }
            wrap.style.display = 'block';
            const score  = [p.length >= 6, /\d/.test(p), /[a-z]/.test(p), /[A-Z]/.test(p), /\W/.test(p)].filter(Boolean).length;
            const levels = [
                { pct: 20,  cls: 'bg-danger',  text: 'Very Weak' },
                { pct: 40,  cls: 'bg-warning', text: 'Weak' },
                { pct: 60,  cls: 'bg-info',    text: 'Fair' },
                { pct: 80,  cls: 'bg-primary', text: 'Strong' },
                { pct: 100, cls: 'bg-success', text: 'Very Strong' },
            ];
            const lvl = levels[score - 1] || levels[0];
            const bar = document.getElementById('strengthBar');
            bar.style.width = lvl.pct + '%';
            bar.className   = 'progress-bar ' + lvl.cls;
            document.getElementById('strengthLabel').textContent = lvl.text;
        });

        document.getElementById('confirmPwd').addEventListener('input', function () {
            const match = this.value === document.getElementById('newPwd').value;
            document.getElementById('matchError').style.display = match ? 'none' : 'block';
        });
    </script>
}
