@using CarShop.Web.ViewModels.Brand
@model BrandViewModel
@{
    ViewData["Title"] = "Create Brand";
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
}

<div class="container-fluid py-4" style="max-width:480px;">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
        <h2 class="mb-0">Create Brand</h2>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-4">
            <form method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">Brand Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter brand name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a href="/Brand" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({ icon:'error', title:'Oops...', text:'@TempData["ErrorMessage"]',
                position:'top-end', timer:5000, toast:true, timerProgressBar:true });
        </script>
    }
}
