@{
    ViewData["Title"] = "Payment Successful";
    bool isSuccess = ViewBag.IsSuccess ?? false;
    string message = ViewBag.Message ?? "";
}

<div class="container mt-5 text-center" style="max-width:500px; margin:auto;">
    @if (isSuccess)
    {
        <div class="display-1 mb-3">✅</div>
        <h2 class="fw-bold text-success mb-2">Payment Confirmed!</h2>
        <p class="text-muted">@message</p>
        <a asp-controller="Order" asp-action="MyOrders" class="btn btn-primary mt-3">View My Orders</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary mt-3 ms-2">Back to Home</a>
    }
    else
    {
        <div class="display-1 mb-3">⚠️</div>
        <h2 class="fw-bold text-warning mb-2">Verification Failed</h2>
        <p class="text-muted">@message</p>
        <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-primary mt-3">My Orders</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary mt-3 ms-2">Back to Home</a>
    }
</div>
