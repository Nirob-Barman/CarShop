@model IEnumerable<CarShop.Application.DTOs.Comment.CommentDto>

@if (Model != null && Model.Any())
{
    <section class="cs-section">
        <div class="container">
            <div class="text-center mb-5">
                <span class="cs-section__eyebrow">Reviews</span>
                <h2 class="cs-section__title">What our customers say</h2>
                <p class="cs-section__sub mx-auto">Real reviews from verified buyers — unfiltered and honest.</p>
            </div>
            <div class="row g-4">
                @foreach (var t in Model)
                {
                    <div class="col-12 col-md-6 col-lg-4 fade-up">
                        <div class="cs-testimonial d-flex flex-column">
                            <div class="cs-testimonial__stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span>@(i <= (t.Rating ?? 0) ? "★" : "☆")</span>
                                }
                            </div>
                            <p class="cs-testimonial__quote flex-grow-1">"@t.Content"</p>
                            <div class="d-flex align-items-center gap-3 mt-auto">
                                <div class="cs-testimonial__avatar">
                                    @(t.UserName?.Length > 0 ? t.UserName[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="cs-testimonial__name">@(t.UserName ?? "Anonymous")</div>
                                    @if (!string.IsNullOrEmpty(t.CarTitle))
                                    {
                                        <div class="cs-testimonial__meta">on @t.CarTitle</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}
