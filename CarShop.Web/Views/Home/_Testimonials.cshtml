@model IEnumerable<CarShop.Application.DTOs.Comment.CommentDto>

@if (Model != null && Model.Any())
{
    <section class="testimonials-section py-5">
        <div class="container">
            <h2 class="text-center fw-bold mb-2">What Our Customers Say</h2>
            <p class="text-center text-muted mb-5">Real reviews from real buyers.</p>
            <div class="row g-4">
                @foreach (var t in Model)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card border-0 shadow-sm h-100 p-4">
                            <!-- Stars -->
                            <div class="mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span style="color:@(i <= (t.Rating ?? 0) ? "#ffc107" : "#dee2e6"); font-size:1.1rem;">★</span>
                                }
                            </div>
                            <!-- Review text -->
                            <p class="text-muted fst-italic mb-3">"@t.Content"</p>
                            <!-- Author -->
                            <div class="mt-auto d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-warning text-dark d-flex align-items-center justify-content-center fw-bold"
                                     style="width:40px;height:40px;font-size:1rem;flex-shrink:0;">
                                    @(t.UserName?.Length > 0 ? t.UserName[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="fw-semibold small">@(t.UserName ?? "Anonymous")</div>
                                    @if (!string.IsNullOrEmpty(t.CarTitle))
                                    {
                                        <div class="text-muted" style="font-size:0.75rem;">on @t.CarTitle</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}
