@using CarShop.Application.DTOs.Wishlist
@model IEnumerable<WishlistItemDto>
@{
    var items = Model.Take(4).ToList();
}

<section class="cs-section">
    <div class="container">
        <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
            <div>
                <span class="cs-section__eyebrow">Saved Cars</span>
                <h2 class="cs-section__title mb-0">Your Wishlist</h2>
            </div>
            <a asp-controller="Wishlist" asp-action="Index" class="cs-section-link align-self-center">
                View All (@Model.Count()) →
            </a>
        </div>
        <div class="cs-car-grid">
            @foreach (var item in items)
            {
                <div class="cs-card cs-wishlist-card">
                    <div class="cs-card__img-wrap">
                        <img src="@item.CarImageUrl" alt="@item.CarTitle" class="cs-card__img" />
                    </div>
                    <div class="cs-card__body">
                        <div class="cs-card__brand">@item.BrandName</div>
                        <div class="cs-card__title">@item.CarTitle</div>
                        <div class="cs-card__footer">
                            <span class="cs-card__price">$@item.CarPrice.ToString("N0")</span>
                        </div>
                    </div>
                    <div class="cs-wishlist-actions">
                        <a asp-controller="Car" asp-action="Details" asp-route-id="@item.CarId"
                           class="cs-wishlist-btn cs-wishlist-btn--buy">Buy Now</a>
                        <form asp-controller="Wishlist" asp-action="Remove" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="carId" value="@item.CarId" />
                            <button type="submit" class="cs-wishlist-btn cs-wishlist-btn--remove" title="Remove from wishlist">♡</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
