@using CarShop.Application.DTOs.Wishlist
@model IEnumerable<WishlistItemDto>
@{
    var items = Model.Take(4).ToList();
}

<section class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold mb-0">♡ Your Wishlist</h2>
        <a asp-controller="Wishlist" asp-action="Index" class="btn btn-outline-dark btn-sm">
            View All (@Model.Count()) →
        </a>
    </div>

    <div class="row g-3">
        @foreach (var item in items)
        {
            <div class="col-6 col-md-3">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@item.CarImageUrl" alt="@item.CarTitle"
                         class="card-img-top" style="height:160px;object-fit:cover;" />
                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-1 text-truncate">@item.CarTitle</h6>
                        <div class="text-muted small mb-2">@item.BrandName</div>
                        <div class="text-success fw-bold">$@item.CarPrice.ToString("N2")</div>
                    </div>
                    <div class="card-footer bg-white border-0 pt-0 px-3 pb-3 d-flex gap-2">
                        <a asp-controller="Car" asp-action="Details" asp-route-id="@item.CarId"
                           class="btn btn-warning btn-sm flex-grow-1 fw-semibold">Buy Now</a>
                        <form asp-controller="Wishlist" asp-action="Remove" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="carId" value="@item.CarId" />
                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Remove from wishlist">♡</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
