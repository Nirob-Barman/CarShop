@using CarShop.Application.DTOs.Wishlist
@model IEnumerable<TopWishlistedCarDto>

<section class="cs-section">
    <div class="container">
        <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
            <div>
                <span class="cs-section__eyebrow">Most Saved</span>
                <h2 class="cs-section__title mb-0">Most Wishlisted</h2>
            </div>
            <a asp-controller="Car" asp-action="AllCars" class="cs-section-link align-self-center">View All →</a>
        </div>
        <div class="cs-car-grid">
            @foreach (var car in Model)
            {
                <div class="cs-card">
                    <span class="cs-wish-count">♥ @car.WishlistCount</span>
                    <div class="cs-card__img-wrap">
                        <img src="@car.CarImageUrl" alt="@car.CarTitle" class="cs-card__img" />
                    </div>
                    <div class="cs-card__body">
                        <div class="cs-card__brand">@car.BrandName</div>
                        <div class="cs-card__title">@car.CarTitle</div>
                        <div class="cs-card__footer">
                            <span class="cs-card__price">$@car.CarPrice.ToString("N0")</span>
                        </div>
                    </div>
                    <a asp-controller="Car" asp-action="Details" asp-route-id="@car.CarId"
                       class="stretched-link" aria-label="View @car.CarTitle"></a>
                </div>
            }
        </div>
    </div>
</section>
