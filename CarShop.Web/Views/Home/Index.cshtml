@{
    ViewData["Title"] = "Home Page";
    var activePromos = ViewBag.ActivePromos as List<CarShop.Application.DTOs.PromoCode.PromoCodeDto>;
    var recentCars   = ViewBag.RecentCars as IEnumerable<CarShop.Web.ViewModels.Car.CarViewModel>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home.css" asp-append-version="true" />
}

<!-- ═══════════════ TIER 1 — SERVER RENDERED ═══════════════ -->

<!-- Hero -->
<section class="cs-hero">
    <div class="container text-center position-relative" style="z-index:1;">
        <div class="cs-hero__badge">🚗 Premium Car Marketplace</div>
        <h1 class="cs-hero__title">
            Find Your<br><em>Dream Car</em>
        </h1>
        <p class="cs-hero__sub">
            Browse hundreds of premium cars, book test drives, and complete secure checkout — all in one place.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Car" asp-action="AllCars" class="cs-hero-btn-primary">
                Browse Cars <span aria-hidden="true">→</span>
            </a>
            @if (!User.Identity!.IsAuthenticated)
            {
                <a asp-controller="Account" asp-action="Register" class="cs-hero-btn-ghost">
                    Create Free Account
                </a>
            }
        </div>

        <div class="cs-search-card">
            @await Html.PartialAsync("_SearchBar")
        </div>
    </div>
</section>

<!-- Stats bar -->
@await Html.PartialAsync("_StatsBanner")

<!-- Promo banner -->
@if (activePromos != null && activePromos.Any())
{
    <div class="cs-promo-wrap">
        @await Html.PartialAsync("_PromoCodeBanner", activePromos)
    </div>
}

<!-- New Arrivals -->
@if (recentCars != null && recentCars.Any())
{
    @await Html.PartialAsync("_NewArrivals", recentCars)
}

<!-- Why Choose Us -->
@await Html.PartialAsync("_WhyChooseUs")

<!-- Test Drive CTA -->
@await Html.PartialAsync("_TestDriveCta")

<!-- ═══════════════ TIER 2 — LAZY LOADED ═══════════════ -->

<!-- Top Rated -->
<div class="lazy-section" data-url="@Url.Action("TopRated", "Home")">
    <section class="cs-skeleton-section cs-skeleton-section--alt">
        <div class="container">
            <div class="placeholder-glow mb-4">
                <span class="placeholder col-2 rounded" style="height:1.5rem;display:block;"></span>
            </div>
            <div class="row g-4">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="col-6 col-md-3">
                        <div class="cs-card">
                            <span class="placeholder col-12 d-block" style="height:200px;"></span>
                            <div class="cs-card__body placeholder-glow">
                                <p class="placeholder col-4 mb-1" style="height:.7rem;"></p>
                                <p class="placeholder col-8 mb-3" style="height:1rem;"></p>
                                <p class="placeholder col-5" style="height:1rem;"></p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
</div>

<!-- Most Wishlisted -->
<div class="lazy-section" data-url="@Url.Action("MostWishlisted", "Home")">
    <section class="cs-skeleton-section">
        <div class="container">
            <div class="placeholder-glow mb-4">
                <span class="placeholder col-3 rounded" style="height:1.5rem;display:block;"></span>
            </div>
            <div class="row g-4">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="col-6 col-md-3">
                        <div class="cs-card">
                            <span class="placeholder col-12 d-block" style="height:200px;"></span>
                            <div class="cs-card__body placeholder-glow">
                                <p class="placeholder col-4 mb-1" style="height:.7rem;"></p>
                                <p class="placeholder col-7 mb-3" style="height:1rem;"></p>
                                <p class="placeholder col-4" style="height:1rem;"></p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
</div>

<!-- Your Wishlist -->
@if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
{
    <div class="lazy-section" data-url="@Url.Action("MyWishlist", "Home")">
        <section class="cs-skeleton-section cs-skeleton-section--alt">
            <div class="container">
                <div class="placeholder-glow mb-4">
                    <span class="placeholder col-2 rounded" style="height:1.5rem;display:block;"></span>
                </div>
                <div class="row g-4">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="col-6 col-md-3">
                            <div class="cs-card">
                                <span class="placeholder col-12 d-block" style="height:200px;"></span>
                                <div class="cs-card__body placeholder-glow">
                                    <p class="placeholder col-4 mb-1" style="height:.7rem;"></p>
                                    <p class="placeholder col-8 mb-3" style="height:1rem;"></p>
                                    <p class="placeholder col-5" style="height:1rem;"></p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    </div>
}

<!-- Recently Viewed -->
<div class="lazy-section" data-url="@Url.Action("RecentlyViewed", "Home")">
    <section class="cs-skeleton-section">
        <div class="container">
            <div class="placeholder-glow mb-4">
                <span class="placeholder col-3 rounded" style="height:1.5rem;display:block;"></span>
            </div>
            <div class="row g-4">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="col-6 col-md-3">
                        <div class="cs-card">
                            <span class="placeholder col-12 d-block" style="height:200px;"></span>
                            <div class="cs-card__body placeholder-glow">
                                <p class="placeholder col-4 mb-1" style="height:.7rem;"></p>
                                <p class="placeholder col-6 mb-3" style="height:1rem;"></p>
                                <p class="placeholder col-4" style="height:1rem;"></p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
</div>

<!-- Testimonials -->
<div class="lazy-section" data-url="@Url.Action("Testimonials", "Home")">
    <section class="cs-skeleton-section cs-skeleton-section--alt">
        <div class="container">
            <div class="placeholder-glow mb-4">
                <span class="placeholder col-3 rounded" style="height:1.5rem;display:block;"></span>
            </div>
            <div class="row g-4">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="col-md-4">
                        <div class="cs-testimonial placeholder-glow">
                            <p class="placeholder col-12 mb-2" style="height:.8rem;"></p>
                            <p class="placeholder col-10 mb-2" style="height:.8rem;"></p>
                            <p class="placeholder col-7 mb-4" style="height:.8rem;"></p>
                            <p class="placeholder col-4" style="height:.8rem;"></p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/js/pages/home.js" asp-append-version="true"></script>
}
