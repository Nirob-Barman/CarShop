@{
    var brands = ViewBag.Brands as IEnumerable<CarShop.Web.ViewModels.Brand.BrandViewModel> ?? Enumerable.Empty<CarShop.Web.ViewModels.Brand.BrandViewModel>();
}

<div class="search-bar-wrapper py-4 px-3">
    <form method="get" asp-controller="Car" asp-action="AllCars" class="row g-2 justify-content-center align-items-end">
        <div class="col-12 col-md-4">
            <input type="text" name="keyword" class="form-control form-control-lg shadow-sm"
                   placeholder="🔍 Search by title or description..." />
        </div>
        <div class="col-6 col-md-2">
            <select name="brandName" class="form-select form-select-lg shadow-sm">
                <option value="">All Brands</option>
                @foreach (var b in brands)
                {
                    <option value="@b.Name">@b.Name</option>
                }
            </select>
        </div>
        <div class="col-6 col-md-2">
            <select name="sortBy" class="form-select form-select-lg shadow-sm">
                <option value="">Newest First</option>
                <option value="price_asc">Price: Low → High</option>
                <option value="price_desc">Price: High → Low</option>
            </select>
        </div>
        <div class="col-6 col-md-1">
            <input type="number" name="minPrice" class="form-control form-control-lg shadow-sm"
                   placeholder="Min $" min="0" />
        </div>
        <div class="col-6 col-md-1">
            <input type="number" name="maxPrice" class="form-control form-control-lg shadow-sm"
                   placeholder="Max $" min="0" />
        </div>
        <div class="col-12 col-md-2">
            <button type="submit" class="btn btn-dark btn-lg w-100 shadow-sm fw-semibold">
                Search Cars
            </button>
        </div>
    </form>
</div>
