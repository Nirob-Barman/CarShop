@model IEnumerable<CarShop.Web.ViewModels.Car.CarViewModel>

@if (Model.Any())
{
    <div class="d-flex flex-wrap justify-content-center gap-4">
        @foreach (var car in Model)
        {
            <div class="col-md-3 col-sm-6 col-12 d-flex">
                <div class="card w-100" style="cursor:pointer;">
                    <img src="@car.ImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@car.Title">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@car.Title</h5>
                        <p class="card-text">Brand: @car.BrandName</p>
                        <p class="card-text">Price: $@car.Price</p>
                        <a href="/Car/Details/@car.Id" class="stretched-link" aria-label="View @car.Title"></a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (ViewBag.ShowAllButton as bool? == true)
    {
        <div class="text-center mt-3 w-100">
            <a href="@Url.Action("AllCars", "Car")" class="btn btn-primary">View All Cars</a>
        </div>
    }
}
else
{
    <h4 class="text-center">No Cars Found</h4>
}
