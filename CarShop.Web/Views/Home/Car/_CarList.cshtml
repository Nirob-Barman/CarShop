@model IEnumerable<CarShop.Web.ViewModels.Car.CarViewModel>

@if (Model.Any())
{
    <div class="cs-car-grid">
        @foreach (var car in Model)
        {
            <div class="cs-card">
                <div class="cs-card__img-wrap">
                    <img src="@(string.IsNullOrEmpty(car.ImageUrl) ? "/images/no-image.png" : car.ImageUrl)"
                         class="cs-card__img" alt="@car.Title" />
                </div>
                <div class="cs-card__body">
                    <div class="cs-card__brand">@car.BrandName</div>
                    <div class="cs-card__title">@car.Title</div>
                    <div class="cs-card__footer">
                        <span class="cs-card__price">$@car.Price.ToString("N0")</span>
                        @if (car.Quantity > 0)
                        {
                            <span class="cs-badge-in">In Stock</span>
                        }
                        else
                        {
                            <span class="cs-badge-out">Sold Out</span>
                        }
                    </div>
                </div>
                <a href="/Car/Details/@car.Id" class="stretched-link" aria-label="View @car.Title"></a>
            </div>
        }
    </div>

    @if (ViewBag.ShowAllButton as bool? == true)
    {
        <div class="text-center mt-4">
            <a href="@Url.Action("AllCars", "Car")" class="cs-section-link">View All Cars →</a>
        </div>
    }
}
else
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:2.5rem;">🚗</div>
        <p class="mt-2 mb-0">No cars found.</p>
    </div>
}
