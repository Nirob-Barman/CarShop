@model (IEnumerable<CarShop.Web.ViewModels.Brand.BrandViewModel>, string)

@{
    var brands = Model.Item1;
    var selectedBrand = Model.Item2 ?? "";
}

<div class="cs-filter-wrap">
    <a href="@Url.Action("")" class="cs-pill @(string.IsNullOrEmpty(selectedBrand) ? "active" : "")">All Brands</a>
    @foreach (var brand in brands!)
    {
        <a href="@Url.Action("", new { brandName = brand.Name })"
           class="cs-pill @(selectedBrand == brand.Name ? "active" : "")">@brand.Name</a>
    }
</div>
