@model IEnumerable<CarShop.Web.ViewModels.Car.CarViewModel>

<section class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">🆕 New Arrivals</h2>
            <p class="text-muted mb-0 small">The latest cars added to our collection.</p>
        </div>
        <a asp-controller="Car" asp-action="AllCars" asp-route-sortBy="newest"
           class="btn btn-outline-dark btn-sm">View All →</a>
    </div>

    <div class="row g-4">
        @foreach (var car in Model)
        {
            <div class="col-12 col-sm-6 col-md-3">
                <div class="card border-0 shadow-sm h-100 car-card">
                    <div class="position-relative">
                        <a asp-controller="Car" asp-action="Details" asp-route-id="@car.Id"
                           class="text-decoration-none">
                            <img src="@(string.IsNullOrEmpty(car.ImageUrl) ? "/images/no-image.png" : car.ImageUrl)"
                                 class="card-img-top" alt="@car.Title"
                                 style="height:180px;object-fit:cover;" />
                        </a>
                        <span class="position-absolute top-0 start-0 m-2 badge bg-dark">New</span>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title fw-semibold mb-1">
                            <a asp-controller="Car" asp-action="Details" asp-route-id="@car.Id"
                               class="text-dark text-decoration-none">@car.Title</a>
                        </h6>
                        <p class="text-muted small mb-2">@car.BrandName</p>
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-success">$@car.Price.ToString("N0")</span>
                            @if (car.Quantity > 0)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle">In Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Sold Out</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
