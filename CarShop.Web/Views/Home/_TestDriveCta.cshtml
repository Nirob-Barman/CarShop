<section class="cs-cta">
    <div class="container position-relative" style="z-index:1;">
        <div class="mx-auto" style="max-width:560px;">
            <span class="cs-section__eyebrow">Test Drive</span>
            <h2 class="cs-cta__title">Want to try before you buy?</h2>
            <p class="cs-cta__sub">
                Book a free test drive on any car — pick your date and time, we handle the rest. No commitment, no pressure.
            </p>
            @if (User.Identity!.IsAuthenticated && !User.IsInRole("Admin"))
            {
                <a asp-controller="TestDrive" asp-action="Book" class="cs-hero-btn-primary">
                    Book a Test Drive →
                </a>
            }
            else if (!User.Identity!.IsAuthenticated)
            {
                <a href="@Url.Action("Login", "Account", new { returnUrl = "/TestDrive/Book" })" class="cs-hero-btn-primary">
                    Book a Test Drive →
                </a>
            }
        </div>
    </div>
</section>
